{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lin275768845/ai-radar-agent/schemas/output.schema.json",
  "title": "AI Radar Agent Output Schema",
  "description": "Scaffold only. This draft schema is not wired into the current runtime; current output artifacts are produced by Python code.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "date": {
      "type": "string",
      "format": "date"
    },
    "evidence_path": {
      "type": "string"
    },
    "report_path": {
      "type": "string"
    },
    "brief_path": {
      "type": "string"
    },
    "publish_result_path": {
      "type": "string"
    },
    "canonical_url": {
      "type": "string"
    },
    "canonical_type": {
      "type": "string",
      "enum": ["docx", "md", "none"]
    },
    "status": {
      "type": "string",
      "description": "Run completion status."
    }
  }
}
