{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lin275768845/ai-radar-agent/schemas/state.schema.json",
  "title": "AI Radar Agent State Schema",
  "description": "Scaffold only. This draft schema is not wired into the current runtime; current state is stored in outputs/<date>/ artifacts.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "run_id": {
      "type": "string"
    },
    "target_date": {
      "type": "string",
      "format": "date"
    },
    "output_dir": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
