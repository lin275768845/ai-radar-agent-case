{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lin275768845/ai-radar-agent/schemas/audit_result.schema.json",
  "title": "AI Radar Agent Audit Result Schema",
  "description": "Scaffold only. This draft schema is not wired into the current runtime; current audits are dataclasses and JSON artifacts.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "run_id": {
      "type": "string"
    },
    "target_date": {
      "type": "string",
      "format": "date"
    },
    "gate": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["pass", "warn", "fail", "skipped"]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
